{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@calo/types": ["packages/types/index.ts"],
      "@calo/database": ["packages/database/index.ts"]
    }
  },
  "exclude": ["node_modules", "apps/web/.next"]
}
